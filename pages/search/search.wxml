<view class="container">
  <!-- Search Header -->
  <view class="search-header">
    <view class="search-input-box">
      <image class="search-icon" src="/images/search-icon.png"></image>
      <input class="search-input" placeholder="关键词、机构、学科多维搜索" value="{{keyword}}" bindinput="onInput" bindconfirm="onSearch" />
    </view>
  </view>

  <!-- Filter Chips -->
  <scroll-view class="filter-scroll" scroll-x="true" enable-flex="true">
    <view class="filter-chip filter-btn" bindtap="toggleFilter">
      <image class="filter-icon" src="/images/filter-icon.png"></image>
      <text>筛选</text>
    </view>
    <view 
      class="filter-chip {{item.selected ? 'active' : ''}}" 
      wx:for="{{filters}}" 
      wx:key="value" 
      bindtap="onFilterTap" 
      data-index="{{index}}"
    >
      {{item.label}}
    </view>
  </scroll-view>

  <!-- Tutor List -->
  <scroll-view class="tutor-list" scroll-y="true">
    <view class="tutor-card" wx:for="{{tutorList}}" wx:key="id" bindtap="navigateToDetail" data-id="{{item.id}}">
      <view class="card-header">
        <image class="avatar" src="{{item.avatar}}"></image>
        <view class="header-info">
          <view class="name-row">
            <text class="name">{{item.name}}</text>
          </view>
          <view class="school">{{item.school}} · {{item.department}}</view>
          <view class="direction" wx:if="{{item.direction}}">核心方向：{{item.direction}}</view>
        </view>
      </view>
      <view class="card-desc">{{item.desc}}</view>
      <view class="tags" wx:if="{{item.tags && item.tags.length > 0}}">
         <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
      </view>
      <view class="title-tag" wx:if="{{item.titleTag}}">{{item.titleTag}}</view>
    </view>
  </scroll-view>

  <!-- Pagination -->
  <view class="pagination">
    <view class="page-btn prev" bindtap="prevPage">上一页</view>
    <view class="page-numbers">
      <view class="page-num {{currentPage === 1 ? 'active' : ''}}" bindtap="goToPage" data-page="1">1</view>
      <view class="page-num {{currentPage === 2 ? 'active' : ''}}" bindtap="goToPage" data-page="2">2</view>
      <view class="page-num {{currentPage === 3 ? 'active' : ''}}" bindtap="goToPage" data-page="3">3</view>
    </view>
    <view class="page-btn next" bindtap="nextPage">下一页</view>
  </view>

  <!-- Filter Popup -->
  <view class="filter-mask {{showFilter ? 'show' : ''}}" bindtap="toggleFilter"></view>
  <view class="filter-popup {{showFilter ? 'show' : ''}}">
    <view class="popup-header">
      <text class="popup-title">筛选条件</text>
      <view class="close-btn" bindtap="toggleFilter">
        <image src="/images/close-icon.png" style="width: 32rpx; height: 32rpx;"></image>
      </view>
    </view>
    <scroll-view class="popup-body" scroll-y="true">
      <view class="filter-section" wx:for="{{filterOptions}}" wx:key="key" wx:for-index="sectionIndex" wx:for-item="section">
        <view class="section-title">{{section.title}}</view>
        <view class="section-options">
          <view 
            class="option-item {{option.selected ? 'active' : ''}}" 
            wx:for="{{section.options}}" 
            wx:key="value" 
            wx:for-index="optionIndex" 
            wx:for-item="option"
            bindtap="selectFilterOption"
            data-section-index="{{sectionIndex}}"
            data-option-index="{{optionIndex}}"
          >
            {{option.label}}
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="popup-footer">
      <view class="reset-btn-large" bindtap="resetFilter">清空</view>
      <view class="confirm-btn-large" bindtap="applyFilter">确定</view>
    </view>
  </view>
</view>
