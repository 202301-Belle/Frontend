/** pages/search/search.wxss */
.container {
  background-color: #f9fafb;
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  position: relative;
}

.search-header {
  background: white;
  padding: 20rpx 30rpx; /* Restore side padding */
  box-shadow: none;
  width: 100%;
  box-sizing: border-box;
}

.search-input-box {
  background: #f3f4f6;
  border-radius: 40rpx; /* Rounded corners */
  height: 80rpx; 
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  margin: 0; 
  width: 100%; /* Full width within parent padding */
  box-sizing: border-box;
}

.search-icon {
  width: 36rpx; 
  height: 36rpx;
  margin-right: 20rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx; 
  color: #333;
  height: 100%;
}

.filter-scroll {
  background: white;
  white-space: nowrap;
  padding: 5rpx 30rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  height: auto; 
  min-height: auto;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  padding: 12rpx 24rpx; /* 6px 12px */
  border-radius: 32rpx; /* 16px */
  font-size: 26rpx; 
  color: #364153;
  margin-right: 16rpx;
  line-height: normal; /* Ensure tight fit */
  height: auto; 
}

.filter-chip.active {
  background: #e6f0ff;
  color: #2b7fff;
  font-weight: 500;
}

.filter-btn {
  padding-left: 20rpx;
  border-radius: 32rpx; /* Match filter-chip radius */
}

.filter-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.tutor-list {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
  padding-bottom: 160rpx; 
}

.tutor-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  margin-bottom: 16rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #eee;
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e2939;
}

.school {
  font-size: 24rpx;
  color: #4a5565;
  margin-bottom: 8rpx;
}

.direction {
  font-size: 24rpx;
  color: #155dfc;
  background: #eff6ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.card-desc {
  font-size: 24rpx;
  color: #4a5565;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tag {
  background: #eff6ff;
  color: #155dfc;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.title-tag {
  font-size: 20rpx;
  color: #155dfc;
  background: #eff6ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  display: inline-block;
}

.pagination {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #f9fafb;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0 60rpx;
  z-index: 10;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.page-btn {
  background: white;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #364153;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.page-numbers {
  display: flex;
  margin: 0 30rpx;
  gap: 16rpx;
}

.page-num {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #364153;
}

.page-num.active {
  background: #2b7fff;
  color: white;
}

/* Filter Popup Styles */
.filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s;
}

.filter-mask.show {
  opacity: 1;
  visibility: visible;
}

.filter-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: white;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.filter-popup.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e2939;
}

.close-btn {
  padding: 10rpx;
}

.popup-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
}

.filter-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.option-item {
  background: #f3f4f6;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #364153;
}

.option-item.active {
  background: #e6f0ff;
  color: #2b7fff;
  font-weight: 500;
}

.popup-footer {
  padding: 30rpx;
  border-top: 1rpx solid #eee;
  background: white;
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.reset-btn-large {
  flex: 1;
  background: #f3f4f6;
  color: #333;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.confirm-btn-large {
  flex: 1;
  background: #2b7fff;
  color: white;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
}
