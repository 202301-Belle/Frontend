/** pages/search/search.wxss */
.container {
  background-color: #f9fafb;
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0;
  position: relative;
}

/* 搜索初始页样式 */
.search-initial {
  flex: 1;
  background-color: #fff;
  display: flex;
  flex-direction: column;
}

.search-header-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(180deg, #e6f7ff 0%, #ffffff 100%);
}

.search-input-wrapper {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  margin-right: 20rpx;
}

.search-icon-small {
  margin-right: 12rpx;
}

.search-input-field {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.placeholder-style {
  color: #999;
}

.search-btn {
  font-size: 30rpx;
  color: #007aff;
  font-weight: bold;
}

.search-discovery {
  padding: 30rpx;
}

.discovery-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.discovery-title text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.refresh-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.discovery-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.discovery-tag {
  background: #f5f5f5;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

/* 筛选容器 (全屏) */
.filter-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: white;
  position: relative;
}

.more-scroll {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
  overflow-y: auto;
  /* 留出底部 bottom-bar 的空间 */
  padding-bottom: 120rpx; 
}

.filter-section {
  margin-bottom: 40rpx;
}

.section-title {
  text-align: left;
  font-weight: bold;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.section-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.option-chip {
  background: #f5f5f5;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #333;
  border: 1rpx solid transparent;
  transition: all 0.2s ease;
}

.option-chip.selected {
  background: #007aff; /* 品牌主色 */
  color: #ffffff; 
  font-weight: bold;
  border: 1rpx solid #007aff;
}

/* 底部固定栏 (筛选模式) */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  box-sizing: border-box;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.count-info {
  font-size: 28rpx;
  color: #007aff;
  font-weight: bold;
}

.btn-confirm {
  background: #007aff;
  color: white;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 结果容器 (列表模式) */
.results-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 重新筛选按钮 */
.btn-re-filter {
  width: calc(100% - 60rpx);
  margin: 30rpx auto;
  background-color: #e6f7ff;
  color: #007aff;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 50rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

/* Tutor List */
.tutor-list {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
  padding-bottom: 160rpx; 
}

.tutor-card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  margin-bottom: 16rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #eee;
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e2939;
}

.school {
  font-size: 24rpx;
  color: #4a5565;
  margin-bottom: 8rpx;
}

.direction {
  font-size: 24rpx;
  color: #155dfc;
  background: #eff6ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.card-desc {
  font-size: 24rpx;
  color: #4a5565;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.tag {
  background: #eff6ff;
  color: #155dfc;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.title-tag {
  font-size: 20rpx;
  color: #155dfc;
  background: #eff6ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  display: inline-block;
}

.pagination {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  background: #f9fafb;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0 60rpx;
  z-index: 10;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.page-btn {
  background: white;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #364153;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}

.page-numbers {
  display: flex;
  margin: 0 30rpx;
  gap: 16rpx;
}

.page-num {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #364153;
}

.page-num.active {
  background: #2b7fff;
  color: white;
}

/* 小屏适配 */
@media screen and (max-width: 320px) {
  .option-chip {
    font-size: 24rpx;
    padding: 8rpx 16rpx;
  }
}