/** pages/user/user.wxss */
.container {
  background-color: #f9fafb;
  min-height: 100vh;
  padding: 0;
  padding-bottom: 40rpx;
  display: block;
}

.user-card {
  background: transparent;
  padding: 0;
  margin: 20rpx;
}

.user-info-bg {
  background: linear-gradient(135deg, #2b7fff 0%, #155dfc 100%);
  border-radius: 32rpx;
  padding: 40rpx;
  color: white;
  box-shadow: 0 10rpx 20rpx rgba(43, 127, 255, 0.3);
  position: relative;
  overflow: hidden;
}

/* Decorative circles */
.user-info-bg::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}

.user-info-bg::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}

.user-main {
  display: flex;
  align-items: center; /* Center vertically */
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 30rpx;
  background-color: #eee;
  flex-shrink: 0;
}

.info-content {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.edit-btn {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.edit-btn image {
  width: 20rpx;
  height: 20rpx;
  margin-left: 6rpx;
}

.vip-tag {
  display: inline-flex;
  align-items: center;
  background: rgba(0,0,0,0.2);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-bottom: 12rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background: #ccc;
  border-radius: 50%;
  margin-right: 8rpx;
}

.phone {
  display: block;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  opacity: 0.9;
}

.role-tag {
  display: inline-flex;
  align-items: center;
  background: rgba(255,255,255,0.2);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.bio {
  background: rgba(255,255,255,0.15);
  padding: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  position: relative;
  z-index: 1;
}

.emoji {
  margin-right: 16rpx;
  font-size: 28rpx;
}

.vip-banner {
  margin: 0 20rpx 30rpx;
  background: linear-gradient(90deg, #333 0%, #1a1a1a 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  color: #ffd700;
  box-shadow: 0 8rpx 16rpx rgba(0,0,0,0.1);
  position: relative;
  z-index: 2;
}

.vip-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffa500 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(255, 215, 0, 0.3);
}

.vip-icon {
  width: 48rpx;
  height: 48rpx;
}

.vip-text {
  flex: 1;
}

.vip-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
  background: linear-gradient(90deg, #ffd700, #fff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.vip-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  color: #ddd;
}

.vip-btn {
  background: linear-gradient(90deg, #ffd700, #ffa500);
  color: #333;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

.feature-grid {
  display: flex;
  justify-content: space-between;
  padding: 0 20rpx;
  margin-bottom: 40rpx;
}

.feature-item {
  background: white;
  width: 216rpx;
  padding: 36rpx 0;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
  transition: transform 0.1s;
}

.feature-item:active {
  transform: scale(0.98);
}

.feature-icon-box {
  width: 88rpx;
  height: 88rpx;
  background: #f0f7ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.feature-icon-box image {
  width: 44rpx;
  height: 44rpx;
}

.feature-item text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.menu-list {
  background: white;
  margin: 0 20rpx 40rpx;
  border-radius: 24rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 24rpx;
}

.menu-left text {
  font-size: 30rpx;
  color: #333;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.3;
}

.logout-btn {
  margin: 0 20rpx 60rpx;
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d4f;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.logout-btn image {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}
